# ==========================================
# 🚀 HELIOS ERP - VARIÁVEIS DE AMBIENTE
# ==========================================

# 📦 BANCO DE DADOS (PostgreSQL)
# Substitua pelas credenciais do seu banco em produção
DATABASE_URL="postgresql://usuario:senha@localhost:5432/helios?schema=public"

# (Opcional) URL direta para o banco, útil caso use Supabase (PgBouncer)
DIRECT_URL="postgresql://usuario:senha@localhost:5432/helios?schema=public"


# 🔐 AUTENTICAÇÃO (JWT)
# Use uma string longa e aleatória em produção. Ex: openssl rand -base64 32
JWT_SECRET="sua_chave_secreta_super_segura_aqui"
JWT_EXPIRATION="7d" # Tempo de expiração do token (ex: 1h, 7d)


# ⚙️ CONFIGURAÇÕES DO SERVIDOR
PORT=3000
NODE_ENV="development" # Mude para "production" quando fizer o deploy